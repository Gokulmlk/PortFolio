# Neon: use the *direct* connection string for migrations (Prisma CLI)
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require"

PORT=4000
FRONTEND_URL=http://localhost:3000

